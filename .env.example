# S-Cubed credentials
SCUBED_USERNAME=yourname@datacentrix.co.za
SCUBED_PASSWORD=your_password_here

# Your IDs — run `python timesheet_bot.py discover` to find these
EMPLOYEE_ID=          # run discover to find yours
ENTITY_ID=1
CLIENT_ID=
PROJECT_ID=
ACTIVITY_ID=
DESIGNATION_ID=

# Timesheet settings
HOURS_PER_DAY=8
WEEKLY_COMMENT=Regular weekly hours

# Set to true to auto-submit for manager approval after saving
SUBMIT_AFTER_SAVE=false

# Set to false to skip Outlook calendar enrichment (Claude history only)
USE_CALENDAR=true

# Folder Claude CLI history is filtered against for project names.
# Default is ./ (wherever you run the script from — put it in your work projects root).
# Override if your work projects live somewhere else.
# WORK_DIR=/home/yourname/projects/work
